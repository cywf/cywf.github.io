---
import Layout from '../layouts/Layout.astro';
import { snapshots, formatSnapshotDate, formatAge, formatNumber } from '../lib/portfolio';
const repos = snapshots.repositories.data.originals || [];
const warnings = [...(snapshots.repositories.data.dataWarnings || []), ...(snapshots.stats.data.dataWarnings || [])];
const stale = repos.filter((r:any)=> Date.now() - Date.parse(r.updatedAt || 0) > 180*86400000);
const needsDocs = repos.filter((r:any)=>!(r.hasWiki||r.hasPages||r.hasReadme));
const needsTriage = repos.filter((r:any)=>r.openIssuesOnly > 25 || r.openPRs > 5);
---
<Layout title="Dashboard" description="Native Astro portfolio operations dashboard with legacy view preserved.">
<section class="command-hero rounded-[2rem] border border-primary/20 bg-base-200 p-6 md:p-10 shadow-2xl mb-8"><p class="badge badge-primary badge-lg mb-4">Native dashboard</p><h1 class="text-4xl md:text-6xl font-black mb-4">Portfolio operations dashboard.</h1><p class="max-w-3xl text-lg text-base-content/75">Static snapshot-backed cards replace the legacy iframe as the primary experience while preserving the legacy view below.</p><p class="mt-4 text-sm text-base-content/60">Data as of {formatSnapshotDate(snapshots.stats.fetchedAt)}</p></section>
<section class="grid gap-4 md:grid-cols-4 mb-8">{[['Original repos', repos.length], ['Forks', snapshots.repositories.data.forkCount], ['Open issues', snapshots.stats.data.openIssuesOnly], ['Open PRs', snapshots.stats.data.openPRs], ['Stale repos', stale.length], ['Missing docs/wiki', needsDocs.length], ['Missing homepage', repos.filter((r:any)=>!(r.homepage||r.pagesUrl)).length], ['Unknown/failing CI', repos.filter((r:any)=>!r.hasWorkflow).length]].map(([l,v]) => <div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="text-xs uppercase tracking-widest text-base-content/60">{l}</h2><p class="text-3xl font-black">{formatNumber(v as number)}</p></div></div>)}</section>
<div class="grid gap-6 lg:grid-cols-2 mb-8">{[['Attention needed', needsTriage], ['Recently active', [...repos].sort((a:any,b:any)=>Date.parse(b.updatedAt)-Date.parse(a.updatedAt)).slice(0,5)], ['Production-ready', repos.filter((r:any)=>r.productionReadinessBand==='Production-ready')], ['Needs docs', needsDocs], ['Needs triage', needsTriage]].map(([title,list]: any) => <section class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">{title}</h2>{list.length ? list.slice(0,6).map((r:any)=><a class="rounded-xl bg-base-100 p-3" href={r.htmlUrl}><strong>{r.name}</strong><p class="text-sm">{r.recommendedNextAction} · {formatAge(r.updatedAt)}</p></a>) : <p>No repositories in this group.</p>}</div></section>)}</div>
<section class="card bg-base-200 shadow-xl mb-8"><div class="card-body"><h2 class="card-title">Data freshness/warnings</h2>{warnings.length ? <ul class="list-disc pl-5">{[...new Set(warnings)].slice(0,6).map(w=><li>{w}</li>)}</ul> : <p>No snapshot warnings.</p>}</div></section>
<details class="rounded-[2rem] border border-base-content/10 bg-base-200 p-4 shadow-2xl"><summary class="cursor-pointer text-xl font-bold">Legacy view</summary><iframe src="/legacy/index.html" title="Legacy portfolio dashboard" class="mt-4 w-full rounded-2xl border border-base-content/10 bg-base-100" style="min-height:min(760px,80vh)"></iframe></details>
</Layout>
