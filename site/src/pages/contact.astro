---
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile';
import { contactIntents } from '../data/portfolio';
---
<Layout title="Contact KP" description="Public-safe contact paths for employment, consulting, speaking, research, and open-source collaboration.">
<section class="command-hero mb-8 rounded-[2rem] bg-base-200 p-8 shadow-xl"><h1 class="text-5xl font-black">Contact and collaboration</h1><p class="mt-4 max-w-3xl">Use approved public channels only. Do not send passwords, tokens, private infrastructure details, or sensitive operational data.</p></section><section class="grid gap-5 md:grid-cols-2"><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Collaboration intents</h2><ul class="list-disc pl-5">{contactIntents.map((intent) => <li>{intent}</li>)}</ul></div></article><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Public channels</h2><a class="link link-primary" href={profile.contact.github}>GitHub</a><a class="link link-primary" href={profile.contact.linkedin}>LinkedIn</a><a class="link link-primary" href="/create-issue">Create a public issue</a></div></article></section>
</Layout>
