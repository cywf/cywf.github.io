---
import Layout from '../layouts/Layout.astro';
const targets = [{title:'Bug report', icon:'🐛', desc:'Broken UI, bad data display, accessibility regressions, or deployment issues.', href:'https://github.com/cywf/cywf.github.io/issues/new?labels=bug&template=bug_report.md&title=%5BBUG%5D%3A+'},{title:'Feature request', icon:'✨', desc:'New portfolio views, data insights, diagrams, or content improvements.', href:'https://github.com/cywf/cywf.github.io/issues/new?labels=enhancement&template=feature_request.md&title=%5BFEATURE%5D%3A+'},{title:'Documentation', icon:'📚', desc:'README, docs route, contribution guidance, or architecture explanation updates.', href:'https://github.com/cywf/cywf.github.io/issues/new?labels=documentation&template=documentation.md&title=%5BDOCS%5D%3A+'},{title:'Choose template', icon:'💡', desc:'Use GitHub’s template chooser when the request spans multiple categories.', href:'https://github.com/cywf/cywf.github.io/issues/new/choose'}];
---
<Layout title="Create Issue" description="Contribution guidance, issue etiquette, and direct GitHub shortcuts for KP portfolio work.">
<section class="command-hero rounded-[2rem] border border-primary/20 bg-base-200 p-6 md:p-10 shadow-2xl mb-8"><p class="badge badge-primary badge-lg mb-4">Contribution path</p><h1 class="text-4xl md:text-6xl font-black mb-4">Open the right request with the right context.</h1><p class="max-w-3xl text-lg text-base-content/75">Use issues for actionable changes, bugs, and docs gaps. Use discussions when the idea needs exploration before it becomes work.</p></section>
<section class="grid gap-6 md:grid-cols-2 mb-8">{targets.map(t => <article class="card bg-base-200 shadow-xl"><div class="card-body"><span class="text-3xl">{t.icon}</span><h2 class="card-title">{t.title}</h2><p>{t.desc}</p><div class="card-actions justify-end"><a class="btn btn-primary" href={t.href} target="_blank" rel="noopener noreferrer">Start on GitHub →</a></div></div></article>)}</section>
<section class="grid gap-6 lg:grid-cols-2"><div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Before you open an issue</h2><ul class="list-disc pl-5 space-y-2"><li>Search existing issues and discussions to avoid duplicates.</li><li>Include expected behavior, actual behavior, screenshots, and reproduction steps for bugs.</li><li>Keep secrets, tokens, private URLs, and workspace variables out of public text.</li><li>Explain the visitor or maintainer outcome, not only the implementation idea.</li></ul></div></div><div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Not sure yet?</h2><p>Read the docs or inspect the public snapshots before filing. If you are proposing a larger direction, start with a discussion-oriented GitHub thread.</p><div class="flex flex-wrap gap-2 mt-3"><a class="btn btn-outline" href="/docs">Read docs</a><a class="btn btn-outline" href="/discussions">View discussions</a><a class="btn btn-outline" href="https://github.com/cywf/cywf.github.io" target="_blank" rel="noopener noreferrer">Repository</a></div></div></div></section>
</Layout>
