---
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile';
import { expertiseDomains } from '../data/expertise';
---
<Layout title="experience" description="KP-DEV-HQ portfolio experience route.">
  <section class="command-hero mb-8 rounded-[2rem] border border-primary/20 bg-base-2 p-6 md:p-10 shadow-2xl bg-base-200">
    <p class="badge badge-primary badge-lg mb-4">Portfolio</p>
    <h1 class="text-4xl md:text-6xl font-black capitalize">experience</h1>
    <p class="mt-4 max-w-3xl text-lg text-base-content/75">Public-safe KP-DEV-HQ experience content for {profile.name}. Detailed claims are intentionally limited to verified public information and clearly labeled placeholders.</p>
  </section>
  <section class="grid gap-4 md:grid-cols-2">
    {expertiseDomains.map((domain) => <article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">{domain.title}</h2><p class="text-base-content/70">{domain.summary}</p></div></article>)}
  </section>
  <section class="mt-8 card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Evidence note</h2><p class="text-base-content/70">Placeholder route scaffold for Phase 1. Phase 2 should replace this with owner-approved case-study detail, evidence labels, and curated content schema expansion where appropriate.</p><div class="card-actions"><a class="btn btn-primary" href="/projects">Selected work</a><a class="btn btn-outline" href="/developer-hq">Developer HQ</a></div></div></section>
</Layout>
