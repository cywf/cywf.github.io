---
import Layout from '../layouts/Layout.astro';
import { experience } from '../data/portfolio';
---
<Layout title="Experience - KP Portfolio" description="Public-safe KP experience, leadership, teaching, and service timeline.">
<section class="command-hero mb-8 rounded-[2rem] bg-base-200 p-8 shadow-xl"><h1 class="text-5xl font-black">Experience and leadership</h1><p class="mt-4 max-w-3xl">A public-safe timeline focused on responsibilities and practice areas, not private employers or invented metrics.</p></section>{experience.map((item) => <article class="card mb-5 bg-base-200 shadow-xl"><div class="card-body"><span class="badge badge-outline w-max">{item.period}</span><h2 class="card-title text-2xl">{item.title}</h2><p class="font-semibold">{item.organization}</p><p>{item.summary}</p><ul class="list-disc pl-5">{item.highlights.map((h) => <li>{h}</li>)}</ul></div></article>)}
</Layout>
