---
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile';
import { expertiseDomains, flagshipProjects, caseStudyDrafts } from '../data/expertise';
---
<Layout title="Kylo Parisher / KP - Portfolio" description="Portfolio-first home for Kylo Parisher / KP, with Developer HQ as public operational evidence.">
  <section class="command-hero mb-8 rounded-[2rem] border border-primary/20 bg-base-200 p-6 shadow-2xl md:p-10"><p class="mb-3 inline-flex rounded-full border border-primary/30 bg-primary/10 px-4 py-2 text-sm font-semibold text-primary">{profile.brand} · professional portfolio</p><h1 class="max-w-5xl text-4xl font-black leading-tight tracking-tight md:text-6xl">{profile.name} / {profile.shortName}: cybersecurity, automation, and developer operations portfolio.</h1><p class="mt-5 max-w-3xl text-lg leading-8 text-base-content/75">{profile.expertiseLine}</p><div class="mt-7 flex flex-wrap gap-3"><a href="/projects" class="btn btn-primary">View selected work</a><a href="/contact" class="btn btn-outline">Contact / collaborate</a><a href="/developer-hq" class="btn btn-ghost">Developer HQ evidence</a></div></section>
  <section class="mb-8 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]"><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Professional summary</h2><p class="text-base-content/75">{profile.summary}</p><p class="text-sm text-base-content/60">This portfolio uses approved public information, placeholders where evidence is incomplete, and static-first rendering for GitHub Pages.</p></div></article><div class="grid gap-4 md:grid-cols-2">{expertiseDomains.map((domain) => <article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-lg">{domain.title}</h2><p class="text-sm text-base-content/70">{domain.summary}</p></div></article>)}</div></section>
  <section class="mb-8 card bg-base-200 shadow-xl"><div class="card-body"><div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between"><div><h2 class="card-title text-2xl">Selected flagship work</h2><p class="text-base-content/70">Curated project records are separated from live operational snapshots.</p></div><a class="link link-primary" href="/projects">Open projects →</a></div><div class="mt-5 grid gap-4 md:grid-cols-3">{flagshipProjects.map((project) => <article class="rounded-2xl border border-base-content/10 bg-base-100 p-5"><span class="badge badge-outline">{project.evidence}</span><h3 class="mt-3 text-xl font-bold"><a class="link link-hover" href={project.href}>{project.title}</a></h3><p class="mt-2 text-sm text-base-content/70">{project.summary}</p></article>)}</div></div></section>
  <section class="mb-8 grid gap-6 lg:grid-cols-2"><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Featured case study preview</h2><p class="text-base-content/75">{caseStudyDrafts[0].title}</p><p class="text-sm text-base-content/60">{caseStudyDrafts[0].statusNote}</p><a class="link link-primary" href="/projects#case-studies">Review draft case studies →</a></div></article><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Experience and leadership preview</h2><p class="text-base-content/75">Public-safe leadership narrative focused on repository governance, documentation discipline, accessibility, and operational transparency.</p><a class="link link-primary" href="/experience">Read experience →</a></div></article></section>
  <section class="mb-8 grid gap-6 lg:grid-cols-2"><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Research and labs preview</h2><p class="text-base-content/75">Browser-local labs remain progressive enhancements, not the core portfolio experience.</p><a class="link link-primary" href="/research">Explore research →</a></div></article><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Developer HQ preview</h2><p class="text-base-content/75">Operational evidence lives under Developer HQ: freshness, readiness, priority work, discussions, docs coverage, and diagrams.</p><a class="link link-primary" href="/developer-hq">Open Developer HQ →</a></div></article></section>
  <section class="rounded-[2rem] border border-primary/20 bg-primary/10 p-6 md:p-10"><h2 class="text-3xl font-black">Contact and collaboration</h2><p class="mt-3 max-w-3xl text-base-content/75">Use the contact route for collaboration context, GitHub review paths, and public-safe next steps.</p><a class="btn btn-primary mt-5" href="/contact">Start a conversation</a></section>
</Layout>
