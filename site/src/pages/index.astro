---
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile';
import { expertiseDomains, projects, caseStudies, experience, researchNotes } from '../data/portfolio';
---
<Layout title="Kylo Parisher / KP - Intelligent Secure Systems Portfolio" description="Portfolio-first home for Kylo Parisher / KP across AI/ML, cybersecurity, secure infrastructure, autonomous agents, space systems, education, and Developer HQ evidence.">
  <section class="command-hero mb-8 rounded-[2rem] border border-primary/20 bg-base-200 p-6 shadow-2xl md:p-10"><p class="mb-3 inline-flex rounded-full border border-primary/30 bg-primary/10 px-4 py-2 text-sm font-semibold text-primary">{profile.brand} · professional portfolio</p><h1 class="max-w-5xl text-4xl font-black leading-tight tracking-tight md:text-6xl">{profile.name} / {profile.shortName} builds intelligent, secure, resilient systems.</h1><p class="mt-5 max-w-3xl text-lg leading-8 text-base-content/75">AI/ML, cybersecurity, secure infrastructure, autonomous agents, space systems research, and education/leadership connected through public-safe, reviewable engineering.</p><div class="mt-7 flex flex-wrap gap-3"><a href="/projects" class="btn btn-primary">View Selected Work</a><a href="/projects" class="btn btn-outline">Explore Projects</a><a href="/about" class="btn btn-ghost">About KP</a><a href="/contact" class="btn btn-outline">Contact</a></div></section>
  <section class="mb-8 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]"><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Professional summary</h2><p class="text-base-content/75">{profile.summary}</p><p class="text-sm text-base-content/60">Developer HQ evidence appears later in the page and under its own route so the first viewport remains portfolio-first.</p></div></article><div class="grid gap-4 md:grid-cols-2">{expertiseDomains.map((domain) => <article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-lg">{domain.title}</h2><p class="text-sm text-base-content/70">{domain.summary}</p></div></article>)}</div></section>
  <section class="mb-8 card bg-base-200 shadow-xl"><div class="card-body"><div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between"><div><h2 class="card-title text-2xl">Selected flagship projects</h2><p class="text-base-content/70">Curated narrative is separate from operational GitHub snapshots.</p></div><a class="link link-primary" href="/projects">Open projects →</a></div><div class="mt-5 grid gap-4 md:grid-cols-3">{projects.filter((p) => p.featured).map((project) => <article class="rounded-2xl border border-base-content/10 bg-base-100 p-5"><span class="badge badge-outline">{project.evidenceLevel}</span><h3 class="mt-3 text-xl font-bold"><a class="link link-hover" href={`/projects#${project.slug}`}>{project.name}</a></h3><p class="mt-2 text-sm text-base-content/70">{project.shortDescription}</p></article>)}</div></div></section>
  <section class="mb-8 grid gap-6 lg:grid-cols-2"><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Featured case study preview</h2><p class="font-semibold">{caseStudies[0].title}</p><p class="text-base-content/75">{caseStudies[0].summary}</p><a class="link link-primary" href="/case-studies#kp-dev-hq-portfolio">Read case studies →</a></div></article><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Experience / leadership preview</h2><p class="font-semibold">{experience[0].title}</p><p class="text-base-content/75">{experience[0].summary}</p><a class="link link-primary" href="/experience">Read experience →</a></div></article></section>
  <section class="mb-8 grid gap-6 lg:grid-cols-2"><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Research / writing and labs</h2><p class="text-base-content/75">{researchNotes[0].summary}</p><div class="mt-3 flex gap-3"><a class="link link-primary" href="/research">Research →</a><a class="link link-primary" href="/labs">Labs →</a></div></div></article><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Developer HQ preview</h2><p class="text-base-content/75">Operational evidence: snapshot freshness, repository health, development board, public activity, docs coverage, and legacy dashboard compatibility.</p><a class="link link-primary" href="/developer-hq">Open Developer HQ →</a></div></article></section>
  <section class="rounded-[2rem] border border-primary/20 bg-primary/10 p-6 md:p-10"><h2 class="text-3xl font-black">Contact and collaboration</h2><p class="mt-3 max-w-3xl text-base-content/75">Use public channels for employment, consulting, instruction, research, or open-source collaboration. Do not send secrets.</p><a class="btn btn-primary mt-5" href="/contact">Start a conversation</a></section>
</Layout>
