---
import Layout from '../layouts/Layout.astro';
import { MermaidViewer } from '../components/MermaidViewer';
import { readdirSync, readFileSync } from 'fs';
import { join } from 'path';
import { snapshots } from '../lib/portfolio';
const descriptions: Record<string,string> = {
  'site-architecture': 'Shows how the public visitor experience is split between native Astro routes, committed snapshots, the preserved legacy dashboard, and GitHub Pages deployment.',
  'data-pipeline': 'Explains why pages can render meaningful HTML first while charts and diagrams remain progressive enhancements.',
  'visitor-journey': 'Maps the intended flow from orientation to evidence to contribution so each route has a clear job.'
};
const mermaidDir = join(process.cwd(), '..', 'mermaid');
const repos = snapshots.repositories.data.originals || [];
const diagrams = readdirSync(mermaidDir).filter(f=>f.endsWith('.mmd')).sort().map(file => ({ name: file.replace('.mmd','').replace(/-/g,' '), key:file.replace('.mmd',''), description: descriptions[file.replace('.mmd','')] || 'Repository architecture diagram derived from the portfolio codebase.', content: readFileSync(join(mermaidDir,file),'utf-8') }));
---
<Layout title="Architecture Visualizer" description="Real Mermaid diagrams for the portfolio architecture, data pipeline, and visitor workflow.">
<section class="command-hero rounded-[2rem] border border-primary/20 bg-base-200 p-6 md:p-10 shadow-2xl mb-8"><p class="badge badge-primary badge-lg mb-4">Systems view</p><h1 class="text-4xl md:text-6xl font-black mb-4">Architecture diagrams for the real portfolio system.</h1><p class="max-w-3xl text-lg text-base-content/75">These Mermaid diagrams live in the repository and describe the actual Astro, snapshot, legacy-dashboard, and GitHub Pages workflow rather than a sample placeholder.</p></section>

<section class="card bg-base-200 shadow-xl mb-8"><div class="card-body"><h2 class="card-title text-2xl">Interactive portfolio graph</h2><p class="text-base-content/70">Nodes represent repos plus docs/wiki, demos, issue pressure, PR pressure, and categories. Export JSON works without a backend; layout uses JavaScript fallback unless a future Wasm layout module is available.</p><div class="flex flex-wrap gap-2 my-3" id="graphFilters"><button class="btn btn-sm" data-filter="all">All</button><button class="btn btn-sm" data-filter="docs">Docs missing</button><button class="btn btn-sm" data-filter="issues">High issue count</button><button class="btn btn-sm" data-filter="stable">Stable/ready</button></div><svg id="repoGraph" viewBox="0 0 900 420" class="w-full rounded-2xl bg-base-100" role="img" aria-label="Repository graph">{repos.map((r:any, i:number) => (<g data-node data-docs={r.hasWiki||r.hasPages||r.hasReadme} data-issues={r.openIssuesOnly} data-band={r.productionReadinessBand}><circle cx={90+(i%4)*210} cy={90+Math.floor(i/4)*140} r={28 + Math.min(18,r.openIssuesOnly)} class="fill-primary opacity-80"></circle><text x={90+(i%4)*210} y={138+Math.floor(i/4)*140} text-anchor="middle" class="fill-current text-xs">{r.name}</text></g>))}</svg><button class="btn btn-outline btn-sm mt-3" id="exportGraph">Download graph JSON</button></div></section>
<script is:inline>
const graphRepos = [];
document.getElementById('exportGraph')?.addEventListener('click',()=>{const a=document.createElement('a');a.href=URL.createObjectURL(new Blob([JSON.stringify(graphRepos,null,2)],{type:'application/json'}));a.download='portfolio-graph.json';a.click();});
document.querySelectorAll('#graphFilters button').forEach(b=>b.addEventListener('click',()=>document.querySelectorAll('[data-node]').forEach(n=>{const f=b.dataset.filter;n.style.display=(f==='all'||(f==='docs'&&n.dataset.docs!=='true')||(f==='issues'&&+n.dataset.issues>25)||(f==='stable'&&['Production-ready','Stable'].includes(n.dataset.band)))?'':'none'})));
</script>
<div class="grid gap-8 lg:grid-cols-[1fr_22rem]"><section class="card bg-base-200 shadow-xl"><div class="card-body"><MermaidViewer client:load diagrams={diagrams} /></div></section><aside class="space-y-4">{diagrams.map(d => <article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title capitalize">{d.name}</h2><p class="text-sm text-base-content/70">{d.description}</p></div></article>)}</aside></div>
</Layout>
