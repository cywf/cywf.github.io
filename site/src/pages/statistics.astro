---
import Layout from '../layouts/Layout.astro';
import { formatSnapshotDate, snapshots, topLanguages, topRepos, formatNumber, percent, repoFallbacks } from '../lib/portfolio';
import { Charts } from '../components/Charts';
const { data: stats, fetchedAt } = snapshots.stats;
const langs = topLanguages(8); const repos = topRepos(8); const totalLang = langs.reduce((s,[,b])=>s+b,0);
const hasData = stats.repoCount > 0 || repos.length > 0 || langs.length > 0;
---
<Layout title="Repository Statistics" description="Static-first repository health, language, momentum, and activity insights for KP's public portfolio.">
  <section class="command-hero rounded-[2rem] border border-primary/20 bg-base-200 p-6 md:p-10 shadow-2xl mb-8">
    <p class="badge badge-primary badge-lg mb-4">Snapshot-backed analytics</p><h1 class="text-4xl md:text-6xl font-black mb-4">Repository statistics that read before JavaScript runs.</h1>
    <p class="max-w-3xl text-lg text-base-content/75">Top-level metrics, language mix, and momentum are rendered into HTML from committed snapshots. Charts enhance the same data when the browser can hydrate them.</p>
    <p class="mt-4 text-sm text-base-content/60">Data as of {formatSnapshotDate(fetchedAt)}</p>
  </section>
  <section class="grid gap-4 md:grid-cols-4 mb-8" aria-label="Top level repository metrics">
    {[['Original repos', stats.repoCount], ['Open issues', stats.openIssuesOnly], ['Open PRs', stats.openPRs], ['Docs/wiki coverage', stats.docsWikiCoverage]].map(([label,value]) => <div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="text-sm uppercase tracking-widest text-base-content/60">{label}</h2><p class="text-4xl font-black">{formatNumber(value as number)}</p></div></div>)}
  </section>
  {!hasData && <div class="alert alert-info mb-8"><span>The current public snapshot is intentionally empty. This usually means the scheduled GitHub data job ran without repository visibility or optional scopes; the page still exposes contracts, expected metrics, and recovery paths.</span></div>}
  <section class="grid gap-8 xl:grid-cols-2 mb-8">
    <div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Language leaders</h2><p class="text-base-content/70">Bytes by primary languages across visible repositories.</p>{langs.length ? <div class="space-y-3 mt-4">{langs.map(([lang,bytes]) => <div><div class="flex justify-between text-sm"><span>{lang}</span><span>{percent(bytes,totalLang)}% · {bytes.toLocaleString()} bytes</span></div><progress class="progress progress-primary" value={bytes} max={langs[0][1]} aria-label={`${lang} ${percent(bytes,totalLang)} percent`}></progress></div>)}</div> : <p class="mt-4 text-base-content/70">Language data is unavailable until repository stats refresh with API visibility.</p>}</div></div>
    <div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Momentum chart</h2><p class="text-base-content/70">The chart is optional enhancement; the list below remains the source-of-truth if scripts fail.</p><Charts client:load stats={stats} /></div></div>
  </section>
  
  <section class="grid gap-8 xl:grid-cols-2 mb-8">
    <div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Open issues by repo</h2><ul class="space-y-2">{repos.map((r:any)=><li class="flex justify-between"><a class="link" href={`${r.htmlUrl}/issues`}>{r.name}</a><span>{r.openIssuesOnly}</span></li>)}</ul></div></div>
    <div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Readiness distribution</h2><ul class="space-y-2">{Object.entries(stats.readinessDistribution || {}).map(([b,c])=><li class="flex justify-between"><span>{b}</span><span>{c as number}</span></li>)}</ul></div></div>
    <div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Open PRs by repo</h2><ul class="space-y-2">{repos.map((r:any)=><li class="flex justify-between"><a class="link" href={`${r.htmlUrl}/pulls`}>{r.name}</a><span>{r.openPRs}</span></li>)}</ul></div></div>
    <div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Metric definitions</h2><ul class="list-disc pl-5"><li>Original repos exclude forks and archived repos.</li><li>Open issues subtract open PRs from GitHub REST open_issues_count.</li><li>Docs coverage counts README, wiki, or Pages/homepage docs signals.</li><li>Readiness uses the 100-point rubric documented in /docs.</li></ul></div></div>
  </section>
<section class="card bg-base-200 shadow-xl mb-8"><div class="card-body"><h2 class="card-title text-2xl">Repository insights</h2><div class="grid gap-4 md:grid-cols-3 mt-4">{repoFallbacks(6).map((repo:any) => <article class="rounded-2xl border border-base-content/10 bg-base-100 p-4"><span class="badge badge-outline">{repo.language || repo.focus || 'Repository'}</span><h3 class="mt-3 font-bold"><a class="link link-hover" href={repo.htmlUrl || repo.url || `https://github.com/cywf/${repo.name}`} target="_blank" rel="noopener noreferrer">{repo.name}</a></h3><p class="mt-2 text-sm text-base-content/70">{repo.description || 'Public project tracked by the portfolio command center.'}</p><p class="mt-3 text-xs text-base-content/60">Stars {formatNumber(repo.stars)} · Forks {formatNumber(repo.forks)} · Issues {formatNumber(repo.openIssuesOnly)} · PRs {formatNumber(repo.openPRs)}</p></article>)}</div></div></section>
</Layout>
