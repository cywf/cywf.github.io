---
import Layout from '../layouts/Layout.astro';
import { researchNotes } from '../data/portfolio';
---
<Layout title="Research and Writing - KP Portfolio" description="KP research notes, writing, architecture decisions, presentations, and experiments.">
<section class="command-hero mb-8 rounded-[2rem] bg-base-200 p-8 shadow-xl"><h1 class="text-5xl font-black">Research / writing</h1><p class="mt-4 max-w-3xl">Working notes and experiments are labeled by status and evidence level.</p></section><section class="grid gap-5 md:grid-cols-3">{researchNotes.map((note) => <article class="card bg-base-200 shadow-xl"><div class="card-body"><span class="badge badge-outline w-max">{note.status}</span><h2 class="card-title">{note.title}</h2><p>{note.summary}</p>{note.links.map((l) => <a class="link link-primary" href={l.href}>{l.label} →</a>)}</div></article>)}</section>
</Layout>
