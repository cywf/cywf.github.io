---
import Layout from '../layouts/Layout.astro';
import { flagshipProjects, caseStudyDrafts } from '../data/expertise';
---
<Layout title="Projects" description="Curated KP-DEV-HQ project catalog with evidence-level labels.">
  <section class="command-hero mb-8 rounded-[2rem] border border-primary/20 bg-base-200 p-6 md:p-10 shadow-2xl"><p class="badge badge-primary badge-lg mb-4">Portfolio catalog</p><h1 class="text-4xl md:text-6xl font-black">Selected projects and case-study drafts.</h1><p class="mt-4 max-w-3xl text-lg text-base-content/75">Curated records stay separate from operational GitHub snapshots. Evidence labels avoid invented metrics or private claims.</p></section>
  <section class="grid gap-4 md:grid-cols-3">{flagshipProjects.map((project) => <article id={project.slug} class="card bg-base-200 shadow-xl"><div class="card-body"><span class="badge badge-outline">{project.evidence}</span><h2 class="card-title">{project.title}</h2><p class="text-base-content/70">{project.summary}</p><a class="link link-primary" href={project.href}>Evidence path →</a></div></article>)}</section>
  <section id="case-studies" class="mt-8 card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Draft case studies</h2><div class="grid gap-4 md:grid-cols-3">{caseStudyDrafts.map((study) => <article class="rounded-2xl bg-base-100 p-5"><span class="badge badge-warning">placeholder</span><h3 class="mt-3 font-bold">{study.title}</h3><p class="mt-2 text-sm text-base-content/70">{study.statusNote}</p></article>)}</div></div></section>
</Layout>
