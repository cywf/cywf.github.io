---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/portfolio';
const domains = [...new Set(projects.flatMap((p) => p.domains))];
---
<Layout title="Projects - KP Portfolio" description="HTML-first KP project catalog with status, domain, and evidence-level labels.">
  <section class="command-hero mb-8 rounded-[2rem] border border-primary/20 bg-base-200 p-6 md:p-10 shadow-2xl"><p class="badge badge-primary badge-lg mb-4">Portfolio catalog</p><h1 class="text-4xl md:text-6xl font-black">Selected projects with evidence labels.</h1><p class="mt-4 max-w-3xl text-lg text-base-content/75">The catalog works without JavaScript. Use browser find or the static domain sections below; labels distinguish verified public evidence from design and research.</p></section>
  <nav class="mb-6 flex flex-wrap gap-2" aria-label="Project domain filters">{domains.map((domain) => <a class="badge badge-outline p-4" href={`#${domain.toLowerCase().replaceAll(' ', '-')}`}>{domain}</a>)}</nav>
  <section class="grid gap-4 md:grid-cols-2">{projects.map((project) => <article id={project.slug} class="card bg-base-200 shadow-xl"><div class="card-body"><div class="flex flex-wrap gap-2"><span class="badge badge-primary">{project.status}</span><span class="badge badge-outline">{project.evidenceLevel}</span>{project.domains.map((d) => <span id={d.toLowerCase().replaceAll(' ', '-')} class="badge">{d}</span>)}</div><h2 class="card-title text-2xl">{project.name}</h2><p>{project.shortDescription}</p><p class="text-sm text-base-content/70"><strong>Problem:</strong> {project.problem}</p>{project.outcome && <p class="text-sm text-base-content/70"><strong>Outcome:</strong> {project.outcome}</p>}<p class="text-sm"><strong>Role:</strong> {project.role.join(', ')}</p><p class="text-sm"><strong>Tech:</strong> {project.technologies.join(', ')}</p><div class="card-actions mt-2">{project.caseStudySlug && <a class="btn btn-sm btn-primary" href={`/case-studies#${project.caseStudySlug}`}>Case study</a>}{project.repositoryUrl && <a class="btn btn-sm btn-outline" href={project.repositoryUrl}>Repository</a>}{project.documentationUrl && <a class="btn btn-sm btn-ghost" href={project.documentationUrl}>Docs</a>}</div></div></article>)}</section>
</Layout>
