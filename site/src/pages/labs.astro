---
import Layout from '../layouts/Layout.astro';
import { labs } from '../data/portfolio';
import { RepoRelationshipGraph } from '../components/labs/RepoRelationshipGraph';
import { ThreatModelSimulator } from '../components/labs/ThreatModelSimulator';
import { WasmReadinessLab } from '../components/labs/WasmReadinessLab';
---
<Layout title="Labs - KP Portfolio" description="Progressively hydrated browser-local KP labs with privacy notes and limitations.">
<section class="command-hero mb-8 rounded-[2rem] bg-base-200 p-8 shadow-xl"><h1 class="text-5xl font-black">Labs catalog</h1><p class="mt-4 max-w-3xl">Labs are progressive enhancements. Browser-local processing and illustrative data are labeled; core explanations remain readable without JavaScript.</p></section><section class="grid gap-5 md:grid-cols-3">{labs.map((lab) => <article class="card bg-base-200 shadow-xl"><div class="card-body"><span class="badge badge-outline w-max">{lab.hydration}</span><h2 class="card-title">{lab.title}</h2><p>{lab.purpose}</p><p class="text-sm"><strong>User:</strong> {lab.user}</p><p class="text-sm"><strong>Input/output:</strong> {lab.inputOutput}</p><p class="text-sm"><strong>Privacy:</strong> {lab.privacy}</p><p class="text-sm"><strong>Limitations:</strong> {lab.limitations}</p><p class="text-sm"><strong>Browser:</strong> {lab.browserRequirements}</p></div></article>)}</section><section class="mt-8 space-y-8" aria-label="Interactive lab enhancements"><div class="rounded-2xl bg-base-200 p-4"><h2 class="text-2xl font-bold">Repository graph enhancement</h2><p>Illustrative public sample, not live topology.</p><RepoRelationshipGraph client:visible /></div><div class="rounded-2xl bg-base-200 p-4"><h2 class="text-2xl font-bold">Threat model simulator</h2><p>Educational browser-local scenario helper.</p><ThreatModelSimulator client:idle /></div><div class="rounded-2xl bg-base-200 p-4"><h2 class="text-2xl font-bold">WASM readiness</h2><p>Local browser capability notes.</p><WasmReadinessLab client:visible /></div></section>
</Layout>
