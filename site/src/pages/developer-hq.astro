---
import Layout from '../layouts/Layout.astro';
import statsSnapshot from '../../public/data/stats.json';
import projectsSnapshot from '../../public/data/projects.json';
import discussionsSnapshot from '../../public/data/discussions.json';
import { developerHqNavigation } from '../data/navigation';
import { caseStudies, expertiseDomains, labs, projects } from '../data/portfolio';
import { buildDeveloperHqSummary } from '../lib/developer-hq';
import { formatSnapshotDate, unwrapSnapshot, type DiscussionsData, type ProjectsData, type StatsData } from '../lib/command-center';

const { data: stats, fetchedAt: statsFetchedAt } = unwrapSnapshot<StatsData>(statsSnapshot);
const { data: projectSnapshot, fetchedAt: projectsFetchedAt } = unwrapSnapshot<ProjectsData>(projectsSnapshot);
const { data: discussions, fetchedAt: discussionsFetchedAt } = unwrapSnapshot<DiscussionsData>(discussionsSnapshot);
const summary = buildDeveloperHqSummary(stats, projectSnapshot, discussions);
const featuredProjects = projects.filter((project) => project.featured && project.public);
const flagshipCaseStudies = caseStudies.slice(0, 3);
const featuredLabs = labs.slice(0, 3);
const proofPoints = [
  `${summary.totals.repos || 'Public'} repositories represented in the current evidence model`,
  `${summary.docsCoverage}% README/wiki coverage captured by public-safe snapshots`,
  `${summary.totals.discussions || 'Recent'} public discussion signals available when GitHub data is present`,
];
---

<Layout
  title="Developer HQ"
  description="KP Developer HQ: a polished portfolio headquarters for systems architecture, selected work, public-safe proof points, labs, and collaboration paths."
>
  <section class="command-hero mb-10 rounded-[2rem] border border-primary/20 bg-base-200 p-6 shadow-2xl md:p-10">
    <p class="badge badge-primary badge-lg mb-4">KP Developer HQ</p>
    <h1 class="max-w-5xl text-4xl font-black md:text-6xl">Portfolio headquarters for public-safe systems building.</h1>
    <p class="mt-5 max-w-3xl text-lg text-base-content/75">
      Kylo Parisher / KP designs static-first portfolio platforms, evidence-aware delivery systems, secure infrastructure patterns, and
      browser-local labs that make technical judgment reviewable without exposing private operations.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a class="btn btn-primary" href="/contact">Start a conversation</a>
      <a class="btn btn-outline" href="/case-studies">Review case studies</a>
      <a class="btn btn-ghost" href="/architecture">Architecture notes</a>
    </div>
  </section>

  <section class="mb-10 grid gap-6 lg:grid-cols-[.9fr_1.1fr]" aria-labelledby="overview-heading">
    <article class="card bg-base-200 shadow-xl">
      <div class="card-body">
        <h2 id="overview-heading" class="card-title text-2xl">Developer HQ overview</h2>
        <p class="text-base-content/75">
          This page is the public front door for KP's engineering story: what gets built, how decisions are made, which evidence is safe to
          publish, and where collaborators can go next.
        </p>
        <ul class="mt-4 space-y-3">
          <li><strong>Systems thinking:</strong> connect product narrative, data contracts, CI gates, and accessible static delivery.</li>
          <li><strong>Security posture:</strong> separate public proof from private telemetry, secrets, and workspace configuration.</li>
          <li><strong>Reviewable delivery:</strong> prefer PR-sized improvements with documented tradeoffs, tests, and rollback paths.</li>
        </ul>
      </div>
    </article>
    <div class="grid gap-4 sm:grid-cols-3">
      {
        expertiseDomains.slice(0, 6).map((domain) => (
          <a
            class="rounded-2xl border border-base-content/10 bg-base-200 p-5 shadow-xl transition hover:-translate-y-1 hover:border-primary focus:outline focus:outline-2 focus:outline-primary"
            href={`/expertise#${domain.slug}`}
          >
            <strong>{domain.title}</strong>
            <p class="mt-2 text-sm text-base-content/70">{domain.summary}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mb-10" aria-labelledby="systems-heading">
    <div class="mb-4 flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.3em] text-primary">Selected systems</p>
        <h2 id="systems-heading" class="text-3xl font-black">Flagship work and case-study paths</h2>
      </div>
      <a class="link link-primary" href="/projects">View all projects</a>
    </div>
    <div class="grid gap-5 lg:grid-cols-3">
      {
        featuredProjects.map((project) => (
          <article class="card bg-base-200 shadow-xl">
            <div class="card-body">
              <span class="badge badge-outline w-max">{project.evidenceLevel}</span>
              <h3 class="card-title">{project.name}</h3>
              <p class="text-base-content/75">{project.shortDescription}</p>
              <p class="text-sm">
                <strong>Outcome:</strong> {project.outcome}
              </p>
              <div class="card-actions justify-end">
                <a class="btn btn-sm btn-primary" href={project.caseStudySlug ? `/case-studies#${project.caseStudySlug}` : project.documentationUrl || '/projects'}>
                  Open evidence
                </a>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mb-10 grid gap-6 lg:grid-cols-2" aria-labelledby="principles-heading">
    <article class="card bg-base-200 shadow-xl">
      <div class="card-body">
        <h2 id="principles-heading" class="card-title text-2xl">Architecture and delivery principles</h2>
        <div class="space-y-4">
          {
            flagshipCaseStudies.map((study) => (
              <section class="rounded-2xl bg-base-100 p-4">
                <h3 class="font-bold">{study.title}</h3>
                <p class="mt-1 text-sm text-base-content/70">{study.summary}</p>
              </section>
            ))
          }
        </div>
      </div>
    </article>
    <article class="card bg-base-200 shadow-xl">
      <div class="card-body">
        <h2 class="card-title text-2xl">Public-safe proof points</h2>
        <p class="text-base-content/75">Operational snapshots support the portfolio story, but they do not control the quality of the public narrative.</p>
        <ul class="mt-4 space-y-3">
          {proofPoints.map((point) => <li class="rounded-2xl bg-base-100 p-4">{point}</li>)}
        </ul>
        <p class="mt-2 text-sm text-base-content/60">
          Snapshot references: projects {formatSnapshotDate(projectsFetchedAt)}, stats {formatSnapshotDate(statsFetchedAt)}, discussions {formatSnapshotDate(discussionsFetchedAt)}.
        </p>
      </div>
    </article>
  </section>

  <section class="mb-10" aria-labelledby="labs-heading">
    <div class="mb-4">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-primary">Labs and research</p>
      <h2 id="labs-heading" class="text-3xl font-black">Browser-local experiments with clear boundaries</h2>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {
        featuredLabs.map((lab) => (
          <article class="rounded-2xl border border-base-content/10 bg-base-200 p-5 shadow-xl">
            <h3 class="font-bold">{lab.title}</h3>
            <p class="mt-2 text-sm text-base-content/70">{lab.purpose}</p>
            <p class="mt-3 text-xs uppercase tracking-wide text-base-content/50">Privacy: {lab.privacy}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="mb-10 grid gap-5 md:grid-cols-2" aria-labelledby="routes-heading">
    <article class="card bg-primary text-primary-content shadow-xl">
      <div class="card-body">
        <h2 class="card-title text-2xl">How to engage</h2>
        <p>
          Use the contact route for employment, consulting, speaking, research, or open-source collaboration. Public issue intake remains available as a support path, not the
          primary portfolio call to action.
        </p>
        <div class="card-actions">
          <a class="btn" href="/contact">Contact KP</a>
          <a class="btn btn-ghost" href="/create-issue">Support issue</a>
        </div>
      </div>
    </article>
    <article class="card bg-base-200 shadow-xl">
      <div class="card-body">
        <h2 id="routes-heading" class="card-title text-2xl">Operational routes, de-emphasized</h2>
        <p class="text-base-content/75">Dashboards and snapshots remain available for reviewers who want implementation evidence.</p>
        <div class="grid gap-2 sm:grid-cols-2">
          {developerHqNavigation.map((item) => <a class="link" href={item.href}>{item.label}</a>)}
        </div>
      </div>
    </article>
  </section>
</Layout>
