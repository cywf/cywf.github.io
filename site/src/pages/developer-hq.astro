---
import Layout from '../layouts/Layout.astro';
import statsSnapshot from '../../public/data/stats.json';
import projectsSnapshot from '../../public/data/projects.json';
import discussionsSnapshot from '../../public/data/discussions.json';
import { developerHqNavigation } from '../data/navigation';
import { buildDeveloperHqSummary } from '../lib/developer-hq';
import { formatSnapshotDate, freshnessLabel, unwrapSnapshot, type DiscussionsData, type ProjectsData, type StatsData } from '../lib/command-center';
const { data: stats, fetchedAt: statsFetchedAt } = unwrapSnapshot<StatsData>(statsSnapshot);
const { data: projects, fetchedAt: projectsFetchedAt } = unwrapSnapshot<ProjectsData>(projectsSnapshot);
const { data: discussions, fetchedAt: discussionsFetchedAt } = unwrapSnapshot<DiscussionsData>(discussionsSnapshot);
const summary = buildDeveloperHqSummary(stats, projects, discussions);
const freshness = freshnessLabel(projectsFetchedAt || statsFetchedAt || discussionsFetchedAt);
---
<Layout title="Developer HQ" description="KP-DEV-HQ operational evidence overview for public snapshots, readiness, activity, docs, and routes.">
  <section class="command-hero mb-8 rounded-[2rem] border border-primary/20 bg-base-200 p-6 md:p-10 shadow-2xl"><p class="badge badge-primary badge-lg mb-4">Developer HQ evidence subsystem</p><h1 class="text-4xl md:text-6xl font-black">Operational evidence, re-parented under Developer HQ.</h1><p class="mt-4 max-w-3xl text-lg text-base-content/75">This overview composes public snapshot data while preserving existing bookmarks for dashboards, statistics, boards, discussions, docs, labs, and visualizers.</p><p class="mt-3 text-sm text-base-content/60">Projects: {formatSnapshotDate(projectsFetchedAt)} · Stats: {formatSnapshotDate(statsFetchedAt)} · Discussions: {formatSnapshotDate(discussionsFetchedAt)}</p></section>
  <section class="mb-8 grid gap-4 md:grid-cols-4" aria-label="Snapshot totals">{Object.entries(summary.totals).map(([label, value]) => <div class="card bg-base-200 shadow-xl"><div class="card-body"><dt class="capitalize text-base-content/60">{label}</dt><dd class="text-4xl font-black">{value}</dd></div></div>)}</section>
  <section class="mb-8 grid gap-6 lg:grid-cols-2"><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Snapshot freshness</h2><span class:list={["badge w-max", freshness.isStale ? 'badge-warning' : 'badge-success']}>{freshness.label}</span>{summary.dataWarnings.length > 0 ? <ul class="mt-4 space-y-2">{summary.dataWarnings.map((w) => <li class="alert alert-warning">{w}</li>)}</ul> : <p class="text-base-content/70">No data warnings were recorded in the stats snapshot.</p>}</div></article><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Readiness and documentation</h2><p>Docs/wiki coverage: <strong>{summary.docsCoverage}%</strong></p><div class="grid gap-2">{Object.entries(summary.readinessDistribution).map(([band, count]) => <p><span class="badge badge-outline mr-2">{band}</span>{count} repositories</p>)}</div></div></article></section>
  <section class="mb-8 grid gap-6 xl:grid-cols-[1.2fr_.8fr]"><article class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Priority work</h2>{summary.priorityItems.length ? <div class="grid gap-3">{summary.priorityItems.map((item) => <article class="rounded-2xl bg-base-100 p-4"><span class="badge badge-primary">{item.rawStatus}</span><h3 class="mt-2 font-bold"><a class="link" href={item.url}>{item.title}</a></h3><p class="text-sm text-base-content/60">{item.repository} · {item.itemType}</p></article>)}</div> : <p>No public project items are present in this snapshot.</p>}</div></article><aside class="space-y-6"><section class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Repository summary</h2>{summary.repos.map((repo) => <a class="block rounded-2xl bg-base-100 p-4" href={repo.htmlUrl || '#'}><strong>{repo.name}</strong><p class="text-sm text-base-content/60">{repo.description || repo.language || 'Public repository'}</p></a>)}</div></section><section class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">Recent public activity</h2>{summary.recentDiscussions.length ? summary.recentDiscussions.map((d) => <a class="link" href={d.url}>{d.repository}: {d.title}</a>) : <p>No discussions captured.</p>}</div></section></aside></section>
  <section class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Developer HQ routes</h2><div class="grid gap-4 md:grid-cols-3">{developerHqNavigation.map((item) => <a class="rounded-2xl border border-base-content/10 bg-base-100 p-5 hover:outline hover:outline-primary" href={item.href}><strong>{item.label}</strong><p class="mt-2 text-sm text-base-content/70">{item.description}</p></a>)}</div></div></section>
</Layout>
