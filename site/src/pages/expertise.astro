---
import Layout from '../layouts/Layout.astro';
import { expertiseDomains } from '../data/portfolio';
---
<Layout title="Expertise - KP Portfolio" description="KP expertise across AI/ML, cybersecurity, secure infrastructure, autonomous agents, space systems, education, and leadership.">
<section class="command-hero mb-8 rounded-[2rem] bg-base-200 p-8 shadow-xl"><h1 class="text-5xl font-black">Expertise domains</h1><p class="mt-4 max-w-3xl">Methods, tools, examples, and evidence paths are public-safe and reviewable.</p></section><section class="grid gap-5 md:grid-cols-2">{expertiseDomains.map((d) => <article id={d.slug} class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">{d.title}</h2><p>{d.summary}</p><h3 class="font-bold">Methods</h3><ul class="list-disc pl-5">{d.methods.map((m) => <li>{m}</li>)}</ul><h3 class="font-bold">Tools</h3><p>{d.tools.join(', ')}</p><h3 class="font-bold">Examples</h3><p>{d.examples.join(', ')}</p>{d.evidenceLinks.map((l) => <a class="link link-primary" href={l.href}>{l.label} →</a>)}</div></article>)}</section>
</Layout>
