---
import Layout from '../layouts/Layout.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import { marked } from 'marked';
import { snapshots, formatAge } from '../lib/portfolio';
const md = readFileSync(join(process.cwd(), '..', 'README.md'), 'utf-8');
marked.use({ gfm: true, breaks: false });
const tokens = marked.lexer(md); let seenH1 = false;
const toc = tokens.filter((t:any)=>t.type==='heading' && t.depth>1 && t.depth<=3).map((t:any)=>({depth:t.depth, text:t.text, slug:t.text.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'')}));
const renderer = new marked.Renderer();
renderer.heading = ({tokens, depth}: any) => { const text = tokens.map((x:any)=>x.raw).join(''); if (depth===1) { if (seenH1) return ''; seenH1=true; } const slug = text.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,''); return `<h${depth} id="${slug}"><a class="anchor" href="#${slug}" aria-label="Link to ${text}">#</a> ${text}</h${depth}>`; };
const htmlContent = marked.parse(md, { renderer }) as string;
const docsIndex = snapshots.docsIndex.data;
const categories = Object.entries(docsIndex.categories || {});
---
<Layout title="Documentation" description="README-driven project documentation rendered through a maintainable Markdown pipeline.">
<section class="command-hero rounded-[2rem] border border-primary/20 bg-base-200 p-6 md:p-10 shadow-2xl mb-8"><p class="badge badge-primary badge-lg mb-4">Product documentation</p><h1 class="text-4xl md:text-6xl font-black mb-4">Documentation for the portfolio and command center.</h1><p class="max-w-3xl text-lg text-base-content/75">README content is rendered with a Markdown parser instead of brittle regex replacements, preserving lists, code blocks, headings, tables, and anchors.</p></section>

<section class="card bg-base-200 shadow-xl mb-8"><div class="card-body"><h2 class="card-title text-2xl">Public Project Wiki Index</h2><p class="text-base-content/70">Generated from the committed docs-index snapshot. Repositories missing descriptions or docs/wiki are intentionally visible.</p>{(docsIndex.dataWarnings || []).length > 0 && <div class="alert alert-warning my-4"><span>{docsIndex.dataWarnings[0]}</span></div>}{categories.map(([category, entries]: any) => <section class="mt-4"><h3 class="text-xl font-bold capitalize">{category}</h3><div class="overflow-x-auto"><table class="table table-sm"><thead><tr><th>Repo</th><th>Description</th><th>Wiki</th><th>Repo</th><th>Homepage</th><th>README</th><th>Pages</th><th>Updated</th><th>Band</th></tr></thead><tbody>{entries.map((r:any) => <tr><th>{r.repo}</th><td>{r.description || 'Missing description'}</td><td>{r.hasWiki ? <a class="link" href={r.wikiUrl}>Wiki</a> : 'Missing'}</td><td><a class="link" href={r.htmlUrl}>GitHub</a></td><td>{r.homepage ? <a class="link" href={r.homepage}>Demo</a> : 'Missing'}</td><td><a class="link" href={r.readmeUrl}>README</a></td><td>{r.hasPages ? 'Yes' : 'No'}</td><td>{formatAge(r.updatedAt)}</td><td>{r.readinessBand}</td></tr>)}</tbody></table></div></section>)}</div></section>
<div class="grid gap-8 lg:grid-cols-[18rem_1fr]"><aside class="card bg-base-200 shadow-xl h-max lg:sticky lg:top-24"><div class="card-body"><h2 class="card-title">Contents</h2><ul class="menu menu-sm">{toc.map(i => <li class={i.depth===3?'ml-4':''}><a href={`#${i.slug}`}>{i.text}</a></li>)}</ul><a class="btn btn-outline btn-sm mt-4" href="https://github.com/cywf/cywf.github.io/blob/main/README.md" target="_blank" rel="noopener noreferrer">Edit on GitHub</a></div></aside><article class="card bg-base-200 shadow-xl"><div class="card-body prose prose-invert max-w-none docs-content"><Fragment set:html={htmlContent} /><hr/><h2 id="migration-notes">Migration notes</h2><p>The portfolio now treats the legacy dashboard as one preserved view inside a broader Astro operations hub. Native routes provide static HTML from snapshot JSON first, then enhance charts and diagrams only where that improves the experience.</p></div></article></div>
</Layout>
