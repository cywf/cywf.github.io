---
import Layout from '../layouts/Layout.astro';
import { snapshots, formatSnapshotDate, formatAge, formatNumber } from '../lib/portfolio';
const repos = snapshots.repositories.data.originals || [];
const projects = snapshots.projects.data;
const noProjects = !projects.itemCount;
const warnings = [...(snapshots.repositories.data.dataWarnings || []), ...(snapshots.workItems.data.dataWarnings || [])];
const issueUrl = (r:any, labels:string, title:string) => `${r.htmlUrl}/issues/new?labels=${encodeURIComponent(labels)}&title=${encodeURIComponent(title)}`;
---
<Layout title="Development Board" description="Static public development board across CYWF non-fork repositories.">
<section class="command-hero rounded-[2rem] border border-primary/20 bg-base-200 p-6 md:p-10 shadow-2xl mb-8"><p class="badge badge-primary badge-lg mb-4">Highest priority route</p><h1 class="text-4xl md:text-6xl font-black mb-4">Public development board for original CYWF projects.</h1><p class="max-w-3xl text-lg text-base-content/75">This board uses repository, issue, pull request, docs, license, CI, and readiness snapshots first. GitHub Projects data remains optional, so the table does not go empty when Projects scopes are unavailable.</p><p class="mt-4 text-sm text-base-content/60">Repository data as of {formatSnapshotDate(snapshots.repositories.fetchedAt)} · Projects as of {formatSnapshotDate(snapshots.projects.fetchedAt)}</p></section>
{noProjects && <div class="alert alert-warning mb-6"><span>Projects data is empty or unavailable, so repo/issue/PR fallback data is driving this board.</span></div>}
{warnings.length > 0 && <section class="alert alert-info mb-6"><div><h2 class="font-bold">Data warnings</h2><ul class="list-disc pl-5">{[...new Set(warnings)].slice(0,5).map(w => <li>{w}</li>)}</ul></div></section>}
<section class="grid gap-4 md:grid-cols-6 mb-8">{[['Original repos', repos.length], ['Forks', snapshots.repositories.data.forkCount], ['Open issues', snapshots.stats.data.openIssuesOnly], ['Open PRs', snapshots.stats.data.openPRs], ['Needs docs', repos.filter((r:any)=>!(r.hasWiki||r.hasPages||r.hasReadme)).length], ['Stable/ready', snapshots.stats.data.stableOrReadyCount]].map(([l,v]) => <div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="text-xs uppercase tracking-widest text-base-content/60">{l}</h2><p class="text-3xl font-black">{formatNumber(v as number)}</p></div></div>)}</section>
<section id="contribute" class="card bg-base-200 shadow-xl mb-8"><div class="card-body"><h2 class="card-title text-2xl">Contribute</h2><p>Use per-repo quick actions for bugs, features, docs issues, open issue lists, pull requests, discussions, and wiki links. Browser secrets are never required.</p></div></section>
<section class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Repository work table</h2><div class="flex flex-wrap gap-2 my-3" data-board-filters><button class="btn btn-sm" data-filter="all">All</button><button class="btn btn-sm" data-filter="risk">High risk</button><button class="btn btn-sm" data-filter="issues">Most open issues</button><button class="btn btn-sm" data-filter="prs">Active PRs</button><button class="btn btn-sm" data-filter="docs">Missing docs</button><button class="btn btn-sm" data-filter="ready">Production-ready</button><button class="btn btn-sm" data-filter="stale">Stale</button></div><div class="overflow-x-auto"><table class="table table-zebra table-pin-rows" aria-label="Development board repositories"><thead><tr><th>Project</th><th>Description</th><th>Links</th><th>Issues</th><th>PRs</th><th>Updated</th><th>Language</th><th>Signals</th><th>Score</th><th>Band</th><th>Next action</th><th>Quick actions</th></tr></thead><tbody>{repos.map((r:any) => <tr data-row data-docs={r.hasWiki||r.hasPages||r.hasReadme} data-band={r.productionReadinessBand} data-issues={r.openIssuesOnly} data-prs={r.openPRs} data-updated={r.updatedAt}><th><a class="link" href={r.htmlUrl}>{r.name}</a></th><td class="min-w-64">{r.description || 'No description captured.'}</td><td><div class="flex flex-col gap-1"><a class="link" href={r.htmlUrl}>Repo</a>{(r.homepage||r.pagesUrl) && <a class="link" href={r.homepage||r.pagesUrl}>Homepage/demo</a>}{r.wikiUrl && <a class="link" href={r.wikiUrl}>Wiki/docs</a>}</div></td><td>{r.openIssuesOnly}</td><td>{r.openPRs}</td><td>{formatAge(r.updatedAt)}</td><td>{r.primaryLanguage || '—'}</td><td>{r.hasWorkflow?'CI ':''}{r.hasReadme?'README ':''}{r.licenseSpdx?'License':''}</td><td>{r.productionReadinessScore}</td><td><span class="badge badge-outline">{r.productionReadinessBand}</span></td><td>{r.recommendedNextAction}</td><td><div class="flex flex-wrap gap-1"><a class="btn btn-xs" href={issueUrl(r,'bug','[BUG]: ')}>Open bug</a><a class="btn btn-xs" href={issueUrl(r,'enhancement','[FEATURE]: ')}>Feature</a><a class="btn btn-xs" href={issueUrl(r,'documentation','[DOCS]: ')}>Docs issue</a><a class="btn btn-xs" href={`${r.htmlUrl}/issues`}>Issues</a><a class="btn btn-xs" href={`${r.htmlUrl}/pulls`}>PRs</a><a class="btn btn-xs" href={`${r.htmlUrl}/discussions`}>Discuss</a>{r.wikiUrl && <a class="btn btn-xs" href={r.wikiUrl}>Wiki</a>}</div></td></tr>)}</tbody></table></div></div></section>
<script is:inline>
  document.querySelectorAll('[data-board-filters] button').forEach((button) => button.addEventListener('click', () => {
    const filter = button.dataset.filter; const rows = [...document.querySelectorAll('[data-row]')];
    rows.sort((a,b)=> filter==='issues' ? (+b.dataset.issues - +a.dataset.issues) : filter==='prs' ? (+b.dataset.prs - +a.dataset.prs) : 0);
    rows.forEach((row) => { const age = (Date.now() - Date.parse(row.dataset.updated || 0)) / 86400000; const show = filter==='all' || (filter==='risk' && !['Production-ready','Stable'].includes(row.dataset.band)) || (filter==='docs' && row.dataset.docs !== 'true') || (filter==='ready' && row.dataset.band === 'Production-ready') || (filter==='stale' && age > 180) || (filter==='issues' && +row.dataset.issues > 0) || (filter==='prs' && +row.dataset.prs > 0); row.hidden = !show; row.parentElement.appendChild(row); });
  }));
</script>
</Layout>
