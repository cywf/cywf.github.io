---
import Layout from '../layouts/Layout.astro';
import { formatSnapshotDate, snapshots, repoFallbacks } from '../lib/portfolio';
import { getStatusCounts } from '../lib/command-center';
const { data: projects, fetchedAt } = snapshots.projects; const items = projects.items || []; const status = getStatusCounts(items); const noAccess = projects.boardCount === 0 && projects.itemCount === 0;
---
<Layout title="Development Board" description="Public cross-project board health with intentional fallbacks when Projects data is unavailable.">
<section class="command-hero rounded-[2rem] border border-primary/20 bg-base-200 p-6 md:p-10 shadow-2xl mb-8"><p class="badge badge-primary badge-lg mb-4">Command center</p><h1 class="text-4xl md:text-6xl font-black mb-4">Development board health, even when Projects snapshots are empty.</h1><p class="max-w-3xl text-lg text-base-content/75">This page separates unavailable Projects access from genuinely empty work queues and falls back to repository-oriented work signals so public visitors still understand the operating model.</p><p class="mt-4 text-sm text-base-content/60">Data as of {formatSnapshotDate(fetchedAt)}</p></section>
<section class="grid gap-4 md:grid-cols-4 mb-8">{[['Repos scanned', projects.repoCount], ['Boards visible', projects.boardCount], ['Tracked items', projects.itemCount], ['Blocked', status.blocked]].map(([l,v]) => <div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="text-sm uppercase tracking-widest text-base-content/60">{l}</h2><p class="text-4xl font-black">{v}</p></div></div>)}</section>
<div class:list={["alert mb-8", noAccess ? 'alert-warning' : 'alert-success']}><span>{noAccess ? 'No GitHub Projects items are present in the public snapshot. This is most likely a visibility or token-scope limitation rather than proof that no work exists.' : 'Projects data is visible and rendered directly into grouped work queues.'}</span></div>
{items.length ? <section class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">{['blocked','doing','todo','done'].map(col => <div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title capitalize">{col}</h2>{items.filter(i=>i.status===col).map(i => <a class="rounded-xl bg-base-100 p-3 hover:outline hover:outline-primary" href={i.url} target="_blank" rel="noopener noreferrer"><span class="badge badge-outline">{i.repository}</span><p class="mt-2 font-semibold">{i.title}</p></a>)}</div></div>)}</section> : <section class="grid gap-6 lg:grid-cols-[1fr_.8fr]"><div class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title text-2xl">Fallback work map</h2><p class="text-base-content/70">Until Projects access is available, the board presents the repositories and contracts that define the public operating surface.</p><div class="grid gap-3 mt-4">{repoFallbacks(3).map((r:any) => <a class="rounded-2xl bg-base-100 p-4 hover:outline hover:outline-primary" href={r.htmlUrl || r.url || `https://github.com/cywf/${r.name}`} target="_blank" rel="noopener noreferrer"><strong>{r.name}</strong><p class="text-sm text-base-content/70">{r.description}</p></a>)}</div></div></div><aside class="card bg-base-200 shadow-xl"><div class="card-body"><h2 class="card-title">How to read this state</h2><ul class="list-disc pl-5 space-y-2 text-base-content/75"><li><strong>Boards visible = 0</strong> means the snapshot could not read public Projects boards.</li><li><strong>Tracked items = 0</strong> means no project cards were returned to the committed JSON contract.</li><li>Repository, docs, and issue paths remain useful contribution entry points.</li></ul><a href="/create-issue" class="btn btn-primary mt-4">Contribute or ask for help</a></div></aside></section>}
</Layout>
