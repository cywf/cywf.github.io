---
import Layout from '../layouts/Layout.astro';
import { formatSnapshotDate, snapshots, formatAge } from '../lib/portfolio';
const { data, fetchedAt } = snapshots.discussions; const discussions = data.discussions || [];
const repos = [...new Set(discussions.map(d=>d.repository))].slice(0,5);
---
<Layout title="Discussions" description="Public GitHub discussion feed and community context for KP projects.">
<section class="command-hero rounded-[2rem] border border-secondary/20 bg-base-200 p-6 md:p-10 shadow-2xl mb-8"><p class="badge badge-secondary badge-lg mb-4">Public conversation layer</p><h1 class="text-4xl md:text-6xl font-black mb-4">Discussions are the collaboration trail around the portfolio.</h1><p class="max-w-3xl text-lg text-base-content/75">Cards are rendered server-side from the latest snapshot so category, repository, age, and outbound CTAs are available without waiting for hydration.</p><p class="mt-4 text-sm text-base-content/60">Data as of {formatSnapshotDate(fetchedAt)} · Active repos: {repos.length ? repos.join(', ') : 'none captured yet'}</p></section>
{discussions.length ? <section class="grid gap-4 md:grid-cols-2">{discussions.map((d:any) => <article class="card bg-base-200 shadow-xl"><div class="card-body"><div class="flex flex-wrap gap-2"><span class="badge badge-secondary">{d.category || 'Discussion'}</span><span class="badge badge-outline">{d.repository}</span><span class="badge badge-ghost">{formatAge(d.updatedAt || d.createdAt)}</span></div><h2 class="card-title mt-2"><a href={d.url} class="link link-hover" target="_blank" rel="noopener noreferrer">{d.title}</a></h2><p class="text-sm text-base-content/70">{d.commentCount ?? 0} comments · started by {d.author || 'GitHub user'}</p><div class="card-actions justify-end"><a class="btn btn-primary btn-sm" href={d.url} target="_blank" rel="noopener noreferrer">Join on GitHub →</a></div></div></article>)}</section> : <div class="alert alert-info"><span>No public discussions were captured in this snapshot. That can mean discussions are disabled, private, or the snapshot token lacks repository access. Use the repository links on the contribution page to start the right conversation.</span></div>}
</Layout>
